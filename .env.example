CHROME_PATH="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
CURRICULUM_URL="https://dreamhack.io/euser/curriculums/916"
TEST_MODE=0

# 드림핵 로그인 정보
DH_EMAIL=your_email@example.com
DH_PASSWORD=your_password

# 자동 로그인 모드 (1=자동, 0=수동)
AUTO_LOGIN=0

# AI Provider (우선순위: Groq → Gemini → DeepSeek)
GROQ_API_KEY=your_groq_api_key
GEMINI_API_KEY=your_gemini_api_key
DEEPSEEK_API_KEY=your_deepseek_api_key

# 로그 레벨 (error, warn, info, debug, verbose)
LOG_LEVEL=info
